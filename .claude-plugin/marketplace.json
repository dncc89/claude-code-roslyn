{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "claude-code-roslyn",
  "metadata": {
    "description": "Roslyn C# Language Server plugin for Claude Code",
    "version": "1.0.6",
    "license": "MIT"
  },
  "owner": { "name": "David" },
  "plugins": [
    {
      "name": "roslyn-ls",
      "version": "1.0.6",
      "source": "./plugins/roslyn-ls",
      "description": "C# language intelligence via Roslyn Language Server with wrapper for Claude Code compatibility.",
      "category": "development",
      "author": { "name": "David" },
      "tags": ["csharp", "dotnet", "roslyn"],
      "lspServers": {
        "roslyn-ls": {
          "command": "roslyn-ls-wrapper",
          "args": [],
          "transport": "stdio",
          "extensionToLanguage": {
            ".cs": "csharp",
            ".csx": "csharp",
            ".cshtml": "csharp"
          },
          "initializationOptions": {},
          "settings": {},
          "startupTimeout": 120000
        }
      }
    }
  ]
}
